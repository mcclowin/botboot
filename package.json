{
  "name": "botboot",
  "version": "0.1.0",
  "description": "Boot AI agents anywhere. One API.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --import ./test/setup.ts --test test/**/*.test.ts",
    "test:unit": "node --import tsx --import ./test/setup.ts --test test/unit/**/*.test.ts",
    "test:integration": "node --import tsx --import ./test/setup.ts --test test/integration/**/*.test.ts",
    "test:e2e": "node --import tsx --import ./test/setup.ts --test test/e2e/**/*.test.ts",
    "test:e2e:openclaw": "node --import tsx --import ./test/setup.ts --test test/e2e/openclaw.test.ts",
    "test:e2e:hermes": "node --import tsx --import ./test/setup.ts --test test/e2e/hermes.test.ts",
    "test:e2e:api": "node --import tsx --import ./test/setup.ts --test test/e2e/api-flow.test.ts",
    "db:migrate": "psql $DATABASE_URL -f sql/schema.sql",
    "hermes:bootstrap:manual": "node --import tsx ./scripts/hermes-bootstrap-manual.js",
    "lint": "eslint src/"
  },
  "keywords": ["ai", "agent", "deployment", "openclaw", "hermes", "infrastructure", "self-hosted"],
  "author": "Brain&Bot <hello@brainandbot.gg>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcclowin/botboot"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "dotenv": "^16.4.0",
    "hono": "^4.6.0",
    "postgres": "^3.4.0",
    "stytch": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
