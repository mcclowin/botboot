# BotBoot live test configuration
# Copy to .env.test for real, non-mocked testing.
# Location: project root (same directory as package.json)

# ── Server ──────────────────────────────────────────
PORT=3001

# ── Database ────────────────────────────────────────
# Use a real local Postgres database dedicated to tests if possible.
DATABASE_URL=postgresql://botboot:botboot-local@localhost:5432/botboot_test

# ── Infrastructure Provider ─────────────────────────
INFRA_PROVIDER=hetzner
HETZNER_API_TOKEN=
HETZNER_SSH_KEY_ID=
HETZNER_SSH_KEY_PATH=/home/ubuntu/.ssh/id_ed25519_hetzner
HETZNER_LOCATION=nbg1
HETZNER_SERVER_TYPE=cx23
HETZNER_FIREWALL_ID=

# ── Secret Encryption ──────────────────────────────
# Generate with: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=

# ── Platform-level live test keys ──────────────────
# At least one of PLATFORM_ANTHROPIC_KEY or PLATFORM_OPENROUTER_KEY is needed
# for real OpenClaw/Hermes boot tests that need model auth.
PLATFORM_ANTHROPIC_KEY=
PLATFORM_OPENROUTER_KEY=
PLATFORM_TAVILY_KEY=
PLATFORM_FIRECRAWL_KEY=

# ── Optional admin key ─────────────────────────────
ADMIN_API_KEY=
