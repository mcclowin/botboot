# BotBoot live product-flow test fixtures
# Copy to .env.test for real, non-mocked testing.
# Location: project root (same directory as package.json)
#
# Infrastructure/runtime values stay in .env.
# This file is only for TEST_* inputs that tests inject through the real BotBoot API.

TEST_ACCOUNT_EMAIL=test@botboot.dev
TEST_ACCOUNT_NAME=BotBoot Test
TEST_MODEL=openai-codex/gpt-5.4
TEST_KEEP_ALIVE_MIN=10
# Or set TEST_KEEP_ALIVE=1 to skip auto-cleanup entirely until you delete manually.
# TEST_KEEP_ALIVE=1

# App/developer test secrets
TEST_ANTHROPIC_API_KEY=
TEST_TAVILY_API_KEY=
TEST_OPENROUTER_API_KEY=
TEST_FIRECRAWL_API_KEY=

# End-user test secrets
TEST_TELEGRAM_BOT_TOKEN=

# OpenAI auth JSON for Codex/OpenAI-style auth profiles.
# Put the raw JSON on ONE line. No extra wrapping quotes.
# Example:
# TEST_OPENAI_AUTH_JSON={"type":"token","provider":"openai","token":"..."}
TEST_OPENAI_AUTH_JSON=
