# BotBoot Configuration
# Copy to .env and fill in your values

# ── Server ──────────────────────────────────────────
PORT=3001

# ── Database ────────────────────────────────────────
# PostgreSQL connection (or Supabase)
DATABASE_URL=postgresql://botboot:password@localhost:5432/botboot

# ── Infrastructure Provider ─────────────────────────
# Which provider to use: hetzner | docker
INFRA_PROVIDER=hetzner

# Hetzner Cloud (required if INFRA_PROVIDER=hetzner)
HETZNER_API_TOKEN=
HETZNER_SSH_KEY_PATH=~/.ssh/id_ed25519
HETZNER_SSH_KEY_ID=
HETZNER_LOCATION=nbg1
HETZNER_SERVER_TYPE=cx23
HETZNER_FIREWALL_ID=

# ── Secret Encryption ──────────────────────────────
# 32-byte hex key for encrypting stored secrets
# Generate with: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=

# ── Platform Secrets (optional fallbacks) ──────────
# These are used when an account/agent doesn't have their own keys
PLATFORM_ANTHROPIC_KEY=
PLATFORM_OPENROUTER_KEY=
PLATFORM_TAVILY_KEY=
PLATFORM_FIRECRAWL_KEY=

# ── Usage Polling ───────────────────────────────────
# Background polling of per-agent LLM usage snapshots
USAGE_POLL_ENABLED=true
USAGE_POLL_INTERVAL_MINUTES=10
USAGE_POLL_STARTUP_DELAY_MS=15000

# ── Admin ──────────────────────────────────────────
# Initial admin API key (generated on first run if empty)
ADMIN_API_KEY=
